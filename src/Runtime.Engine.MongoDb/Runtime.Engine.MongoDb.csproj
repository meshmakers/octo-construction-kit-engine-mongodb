<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <Description>Octo Mesh Runtime Engine for MongoDB.</Description>
        <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
        <AssemblyName>Meshmakers.Octo.Runtime.Engine.MongoDb</AssemblyName>
        <RootNamespace>Meshmakers.Octo.Runtime.Engine.MongoDb</RootNamespace>
        <Configurations>Debug;Release;DebugL</Configurations>
        <Platforms>AnyCPU</Platforms>
        <OutputPath>..\..\bin\$(Configuration)\</OutputPath>
        <NoWarn>1701;1702;CS8002</NoWarn>
    </PropertyGroup>

    <ItemGroup Condition="'$(Configuration)'!='DebugL'">
        <PackageReference Include="Meshmakers.Common.Metrics" Version="4.0.2312.30002" />
        <PackageReference Include="Meshmakers.Octo.ConstructionKit.Engine" Version="3.0.19" />
        <PackageReference Include="Meshmakers.Octo.Runtime.Engine" Version="3.0.19" />
        <PackageReference Include="Meshmakers.Octo.ConstructionKit.Models.System" Version="3.0.19" />
    </ItemGroup>

    <ItemGroup Condition="'$(Configuration)'=='DebugL'">
        <PackageReference Include="Meshmakers.Common.Metrics" Version="999.0.0" />
        <PackageReference Include="Meshmakers.Octo.ConstructionKit.Engine" Version="999.0.0" />
        <PackageReference Include="Meshmakers.Octo.Runtime.Engine" Version="999.0.0" />
        <PackageReference Include="Meshmakers.Octo.ConstructionKit.Models.System" Version="999.0.0" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="MathParser.org-mXparser" Version="5.2.1" />
        <PackageReference Include="Microsoft.Extensions.Caching.Memory" Version="8.0.0" />
        <PackageReference Include="MongoDB.Driver.GridFS" Version="2.23.1" />
        <PackageReference Include="NLog" Version="5.2.8" />
        <PackageReference Include="System.Reactive" Version="6.0.0" />
        <PackageReference Include="MongoDB.Bson" Version="2.23.1" />
        <PackageReference Include="MongoDB.Driver" Version="2.23.1" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\Runtime.Contracts.MongoDb\Runtime.Contracts.MongoDb.csproj" />
    </ItemGroup>

    <ItemGroup>
        <None Include="..\..\assets\meshmakers64.png">
            <Pack>True</Pack>
            <PackagePath />
            <Link>meshmakers64.png</Link>
        </None>
    </ItemGroup>

    <ItemGroup>
        <None Include="..\..\LICENSE">
            <Pack>True</Pack>
            <PackagePath />
            <Link>LICENSE</Link>
        </None>
    </ItemGroup>

</Project>